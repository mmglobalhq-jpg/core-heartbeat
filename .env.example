# core-heartbeat environment configuration — TEMPLATE.
# Copy to `.env` and fill in real values. `.env` is gitignored; never commit real keys.

# Core Gateway Settings
HEARTBEAT_CONFIDENCE_THRESHOLD=0.5

# Google Gemini — default Supervisor provider (model_preference "gemini-2.5-flash").
GEMINI_API_KEY=your-gemini-api-key

# OpenAI — Supervisor path for model_preference "gpt-4o-mini".
OPENAI_API_KEY=your-openai-api-key

# Anthropic — Supervisor path for model_preference "claude-3.5-haiku" (routes to claude-haiku-4-5).
ANTHROPIC_API_KEY=your-anthropic-api-key

# Local Ollama worker.
# OLLAMA_URL MUST include the /api/generate path — a bare host (http://localhost:11434)
# hits the wrong endpoint (HTTP 405) and degrades every local_llm call.
OLLAMA_URL=http://localhost:11434/api/generate
OLLAMA_MODEL=qwen2.5:7b

# Supabase — multi-user memory bridge + per-user vault sync (Phase 2).
# SUPABASE_URL / SUPABASE_ANON_KEY: project API endpoint + publishable client key.
SUPABASE_URL=your-supabase-project-url
SUPABASE_ANON_KEY=your-supabase-anon-or-publishable-key
# SUPABASE_SERVICE_ROLE_KEY: server-only key that BYPASSES RLS. Required by the
# fixed-income fund-holdings tools (tools/fund_holdings.py) to read the RLS-
# protected fund-tracker tables. Never expose this to the browser / NEXT_PUBLIC.
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
# S3-compatible Storage access for the `user-vaults` bucket. Generate the ID/secret
# in Dashboard -> Storage -> S3 Access Keys (the secret is shown only once).
SUPABASE_S3_ENDPOINT=your-supabase-s3-storage-endpoint
SUPABASE_S3_ACCESS_KEY_ID=your-supabase-s3-access-key-id
SUPABASE_S3_SECRET_ACCESS_KEY=your-supabase-s3-secret-access-key
# HS256 signing secret for local Bearer-JWT verification (auth.verify_supabase_jwt).
# Dashboard -> Project Settings -> API -> JWT Secret. Blank = every caller resolves
# to the sandbox user (verification degrades gracefully with a warning).
SUPABASE_JWT_SECRET=your-supabase-jwt-secret
